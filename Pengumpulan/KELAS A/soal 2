#include <iostream>
using namespace std;

const int MAX = 5;

//STACK
string stackBuku[MAX];
int top = -1;

// cek stack kosong
bool isEmptyStack() {
    return top == -1;
}

// cek stack penuh
bool isFullStack() {
    return top == MAX - 1;
}

// push
void push(string judul) {

    if (isFullStack()) {

        cout << "Stack penuh!\n";

    } else {

        top++;
        stackBuku[top] = judul;

        cout << "Buku berhasil ditambahkan.\n";
    }
}

// pop
void pop() {

    if (isEmptyStack()) {

        cout << "Stack kosong!\n";

    } else {

        cout << "Buku \"" << stackBuku[top]
             << "\" berhasil dihapus.\n";

        top--;
    }
}

// peek
void peekStack() {

    if (isEmptyStack()) {

        cout << "Stack kosong!\n";

    } else {

        cout << "Buku paling atas : "
             << stackBuku[top] << endl;
    }
}

// tampil stack
void tampilStack() {

    if (isEmptyStack()) {

        cout << "Stack kosong!\n";

    } else {

        cout << "\nIsi Stack Buku:\n";

        for (int i = top; i >= 0; i--) {

            cout << i + 1
                 << ". "
                 << stackBuku[i] << endl;
        }
    }
}

// QUEUE

string queueAnggota[MAX];

int front = 0;
int rear = -1;
int jumlah = 0;

// cek queue kosong
bool isEmptyQueue() {
    return jumlah == 0;
}

// cek queue penuh
bool isFullQueue() {
    return jumlah == MAX;
}

// enqueue
void enqueue(string nama) {

    if (isFullQueue()) {

        cout << "Queue penuh!\n";

    } else {

        rear++;
        queueAnggota[rear] = nama;

        jumlah++;

        cout << nama
             << " berhasil masuk antrean.\n";
    }
}

// dequeue
void dequeue() {

    if (isEmptyQueue()) {

        cout << "Queue kosong!\n";

    } else {

        cout << queueAnggota[front]
             << " keluar dari antrean.\n";

        front++;
        jumlah--;
    }
}

// peek queue
void peekQueue() {

    if (isEmptyQueue()) {

        cout << "Queue kosong!\n";

    } else {

        cout << "Antrean terdepan : "
             << queueAnggota[front] << endl;
    }
}

// tampil queue
void tampilQueue() {

    if (isEmptyQueue()) {

        cout << "Queue kosong!\n";

    } else {

        cout << "\nIsi Queue:\n";

        for (int i = front; i <= rear; i++) {

            cout << i - front + 1
                 << ". "
                 << queueAnggota[i] << endl;
        }
    }
}

// MAIN

int main() {

    int jumlahBuku, jumlahAnggota;
    string judul, nama;

    // STACK
   
    cout << "===== STACK : TUMPUKAN BUKU =====\n";

    cout << "Masukkan jumlah buku (maks 5): ";
    cin >> jumlahBuku;
    cin.ignore();

    for (int i = 0; i < jumlahBuku; i++) {

        cout << "Masukkan judul buku ke-"
             << i + 1 << " : ";

        getline(cin, judul);

        push(judul);
    }

    tampilStack();

    cout << endl;
    peekStack();

    cout << "\nPop 2 buku\n";

    pop();
    pop();

    tampilStack();

    // QUEUE

    cout << "\n\n===== QUEUE : ANTRIAN PEMINJAMAN =====\n";

    cout << "Masukkan jumlah anggota (maks 5): ";
    cin >> jumlahAnggota;
    cin.ignore();

    for (int i = 0; i < jumlahAnggota; i++) {

        cout << "Masukkan nama anggota ke-"
             << i + 1 << " : ";

        getline(cin, nama);

        enqueue(nama);
    }

    tampilQueue();

    cout << endl;
    peekQueue();

    cout << "\nDequeue 1 anggota\n";

    dequeue();

    tampilQueue();

    cout << "\nMasukkan anggota baru : ";
    getline(cin, nama);

    enqueue(nama);

    tampilQueue();

    return 0;
}