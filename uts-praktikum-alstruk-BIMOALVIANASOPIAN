#include <iostream>
using namespace std;

// ================= STACK =================
class Stack {

private:
    string data[5];
    int top;

public:

    Stack() {
        top = -1;
    }

    bool isEmpty() {
        return top == -1;
    }

    bool isFull() {
        return top == 4;
    }

    void push(string nilai) {

        if(isFull()) {
            cout << "Stack penuh!\n";
        }
        else {
            top++;
            data[top] = nilai;

            cout << nilai << " berhasil ditambahkan.\n";
        }
    }

    void pop() {

        if(isEmpty()) {
            cout << "Stack kosong!\n";
        }
        else {

            cout << data[top] << " berhasil dihapus.\n";
            top--;
        }
    }

    void peek() {

        if(isEmpty()) {
            cout << "Stack kosong!\n";
        }
        else {
            cout << "Data teratas : " << data[top] << endl;
        }
    }

    void tampil() {

        cout << "\nIsi Stack:\n";

        for(int i = top; i >= 0; i--) {
            cout << "- " << data[i] << endl;
        }
    }
};

// ================= QUEUE =================
class Queue {

private:
    string data[5];
    int front, rear;

public:

    Queue() {

        front = 0;
        rear = -1;
    }

    bool isEmpty() {
        return rear < front;
    }

    bool isFull() {
        return rear == 4;
    }

    void enqueue(string nama) {

        if(isFull()) {
            cout << "Queue penuh!\n";
        }
        else {

            rear++;
            data[rear] = nama;

            cout << nama << " masuk ke antrian.\n";
        }
    }

    void dequeue() {

        if(isEmpty()) {
            cout << "Queue kosong!\n";
        }
        else {

            cout << data[front] << " keluar dari antrian.\n";
            front++;
        }
    }

    void peek() {

        if(isEmpty()) {
            cout << "Queue kosong!\n";
        }
        else {
            cout << "Antrian depan : " << data[front] << endl;
        }
    }

    void tampil() {

        cout << "\nIsi Queue:\n";

        for(int i = front; i <= rear; i++) {
            cout << "- " << data[i] << endl;
        }
    }
};

int main() {

    cout << "=====================================\n";
    cout << "       PROGRAM STACK & QUEUE\n";
    cout << "=====================================\n";

    // STACK
    Stack s;

    cout << "\n========== STACK ==========\n";

    s.push("T001");
    s.push("T002");
    s.push("T003");
    s.push("T004");

    s.peek();
    s.tampil();

    cout << "\nMenghapus data...\n";

    s.pop();
    s.pop();

    s.tampil();

    // QUEUE
    Queue q;

    cout << "\n========== QUEUE ==========\n";

    q.enqueue("Budi");
    q.enqueue("Sari");
    q.enqueue("Eko");

    q.peek();
    q.tampil();

    cout << "\nMemproses antrian...\n";

    q.dequeue();

    q.enqueue("Dewi");

    q.tampil();

    cout << "\n=====================================\n";
    cout << "         PROGRAM SELESAI\n";
    cout << "=====================================\n";

    return 0;
}
