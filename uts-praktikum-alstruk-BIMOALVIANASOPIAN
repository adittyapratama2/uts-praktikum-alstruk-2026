        cout << "Harga Buku     : ";
        cin >> buku[i].harga;
        cin.ignore();
    }

    // OUTPUT TABEL
    cout << "\n\n==============================================";
    cout << "\n             DATA SELURUH BUKU";
    cout << "\n==============================================\n";

    cout << left
         << setw(5)  << "No"
         << setw(20) << "Judul"
         << setw(20) << "Pengarang"
         << setw(10) << "Tahun"
         << "Harga\n";

    cout << "---------------------------------------------------------------\n";

    for(int i = 0; i < n; i++) {

        cout << left
             << setw(5)  << i + 1
             << setw(20) << buku[i].judul
             << setw(20) << buku[i].pengarang
             << setw(10) << buku[i].tahun
             << buku[i].harga << endl;
    }

    // HARGA TERTINGGI
    int max = 0;

    for(int i = 1; i < n; i++) {
        if(buku[i].harga > buku[max].harga) {
            max = i;
        }
    }

    cout << "\n==============================================\n";
    cout << "        BUKU DENGAN HARGA TERTINGGI\n";
    cout << "==============================================\n";

    cout << "Judul      : " << buku[max].judul << endl;
    cout << "Pengarang  : " << buku[max].pengarang << endl;
    cout << "Tahun      : " << buku[max].tahun << endl;
    cout << "Harga      : " << buku[max].harga << endl;

    // RATA-RATA
    float total = 0;

    for(int i = 0; i < n; i++) {
        total += buku[i].harga;
    }

    cout << "\nRata-rata harga buku : " << total / n << endl;

    // PENCARIAN TAHUN
    int cari;
    bool ketemu = false;

    cout << "\nMasukkan tahun yang dicari : ";
    cin >> cari;

    cout << "\nHasil pencarian:\n";

    for(int i = 0; i < n; i++) {

        if(buku[i].tahun == cari) {

            cout << "- " << buku[i].judul << endl;
            ketemu = true;
        }
    }

    if(!ketemu) {
        cout << "Data buku tidak ditemukan.\n";
    }

    cout << "\n=====================================\n";
    cout << "        PROGRAM SELESAI\n";
    cout << "=====================================\n";

    return 0;
}

